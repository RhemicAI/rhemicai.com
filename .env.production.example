# Google Analytics 4 Measurement ID
# Get this from: GA4 Admin > Data Streams > Web > Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Site origin used in verification links
NEXT_PUBLIC_SITE_URL=https://rhemicai.com

# Careers hiring intake
CLICKUP_API_TOKEN=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLICKUP_APPLICATION_LIST_ID=901714101330
# Consult Leak Calculator lead capture
CLICKUP_INBOUND_LEADS_LIST_ID=901714155246
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HIRING_EMAIL_FROM="Rhemic AI <contact@rhemicai.com>"
HIRING_EMAIL_REPLY_TO="contact@rhemicai.com"
HIRING_VERIFY_SECRET=replace-with-long-random-secret

# AI scoring. AI score is triage only; human review is mandatory before any candidate communication or decision.
HIRING_AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_HIRING_MODEL=deepseek-v4-pro

# OpenAI alternative. Only set these when HIRING_AI_PROVIDER=openai.
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_HIRING_MODEL=gpt-4.1-mini

# Cal.com booking webhook -> Sales Call Pipeline sync
# CLICKUP_SALES_PIPELINE_LIST_ID is the ClickUp list that receives booked-call tasks.
# CAL_WEBHOOK_SECRET is the signing secret configured in the Cal.com webhook settings.
CLICKUP_SALES_PIPELINE_LIST_ID=901714155435
CAL_WEBHOOK_SECRET=replace-with-cal-webhook-secret
